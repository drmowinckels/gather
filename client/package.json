{
  "name": "samkoma-client",
  "version": "0.1.0",
  "description": "Tiny, dependency-free client for the samkoma scheduling API",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@samkoma/core": "*",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "~2.1.8"
  }
}
